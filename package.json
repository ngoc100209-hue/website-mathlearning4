{
  "name": "mathsign-nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001",
    "dev:safe": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-safe.ps1",
    "dev:network": "next dev --hostname 0.0.0.0 --port 3001",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:reset": "prisma migrate reset",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@clerk/localizations": "^4.12.0",
    "@clerk/nextjs": "^6.21.2",
    "@google/genai": "^2.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^5.21.1",
    "@types/nodemailer": "^8.0.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "next": "^15.1.3",
    "nodemailer": "^9.0.3",
    "pg": "^8.21.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^22.20.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.5.20",
    "postcss": "^8.5.15",
    "prisma": "^5.21.1",
    "tailwindcss": "^4.1.14",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.2"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
